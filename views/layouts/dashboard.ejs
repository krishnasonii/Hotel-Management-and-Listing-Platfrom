<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard</title>
    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <!-- Chart.js -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <!-- Custom CSS -->
    <link rel="stylesheet" href="/css/dashboard.css">
</head>
<body>

    <div class="dashboard-wrapper">
        <!-- SIDEBAR -->
        <aside class="sidebar">
            <div class="sidebar-header">
                <div class="logo">
                </div>
                <button id="sidebarClose" class="d-md-none"><i class="fa-solid fa-xmark"></i></button>
            </div>
            
            <nav class="sidebar-nav">
                <a href="/listings" class="nav-item">
                    <i class="fa-solid fa-house"></i> <span>Explore Hotels</span>
                </a>
                <div class="nav-divider"></div>

                <% if (currUser && currUser.role === 'admin') { %>
                    <a href="/admin/dashboard" class="nav-item <%= (typeof activePage !== 'undefined' && activePage === 'dashboard') ? 'active' : '' %>">
                        <i class="fa-solid fa-chart-line"></i> <span>Admin Dashboard</span>
                    </a>
                    <a href="/admin/hotels" class="nav-item <%= (typeof activePage !== 'undefined' && activePage === 'hotels') ? 'active' : '' %>">
                        <i class="fa-solid fa-hotel"></i> <span>Manage Hotels</span>
                    </a>
                    <a href="/admin/rooms" class="nav-item <%= (typeof activePage !== 'undefined' && activePage === 'rooms') ? 'active' : '' %>">
                        <i class="fa-solid fa-bed"></i> <span>Manage Rooms</span>
                    </a>
                    <a href="/admin/users" class="nav-item <%= (typeof activePage !== 'undefined' && activePage === 'users') ? 'active' : '' %>">
                        <i class="fa-solid fa-users"></i> <span>Manage Users</span>
                    </a>
                    <a href="/admin/reports" class="nav-item <%= (typeof activePage !== 'undefined' && activePage === 'reports') ? 'active' : '' %>">
                        <i class="fa-solid fa-file-invoice-dollar"></i> <span>Reports</span>
                    </a>
                <% } else { %>
                    <a href="/user/dashboard" class="nav-item <%= (typeof activePage !== 'undefined' && activePage === 'dashboard') ? 'active' : '' %>">
                        <i class="fa-solid fa-gauge"></i> <span>User Dashboard</span>
                    </a>
                    <a href="/user/bookings" class="nav-item <%= (typeof activePage !== 'undefined' && activePage === 'bookings') ? 'active' : '' %>">
                        <i class="fa-solid fa-calendar-check"></i> <span>My Bookings</span>
                    </a>
                    <a href="/user/orders" class="nav-item <%= (typeof activePage !== 'undefined' && activePage === 'orders') ? 'active' : '' %>">
                        <i class="fa-solid fa-utensils"></i> <span>My Orders</span>
                    </a>
                    <a href="/user/profile" class="nav-item <%= (typeof activePage !== 'undefined' && activePage === 'profile') ? 'active' : '' %>">
                        <i class="fa-regular fa-user"></i> <span>Profile</span>
                    </a>
                <% } %>
                <div class="nav-divider"></div>
                <a href="/logout" class="nav-item text-danger mt-auto">
                    <i class="fa-solid fa-power-off"></i> <span>Sign out</span>
                </a>
            </nav>
        </aside>

        <!-- MAIN CONTENT -->
        <main class="main-panel">
            <!-- Top Header -->
            <header class="dashboard-header">
                <div class="header-left">
                    <button id="sidebarToggle" class="d-md-none me-3"><i class="fa-solid fa-bars"></i></button>
                    <h4 class="mb-0"><%= (currUser && currUser.role === 'admin') ? 'Admin Panel' : 'Customer Dashboard' %></h4>
                </div>
                
                <div class="header-right d-flex align-items-center">
                    <div class="header-icons d-flex align-items-center">
                        <a href="/user/wishlist" class="text-secondary position-relative me-3" title="Wishlist">
                            <i class="fa-regular fa-heart fa-lg"></i>
                            <% if (currUser.wishlist && currUser.wishlist.length > 0) { %>
                                <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger border border-white" style="font-size: 0.5rem; padding: 0.25em 0.4em;">
                                    <%= currUser.wishlist.length %>
                                </span>
                            <% } %>
                        </a>
                        <a href="/user/cart" class="text-secondary position-relative me-3" title="Cart">
                            <i class="fa-solid fa-cart-shopping fa-lg"></i>
                            <% if (currUser.cart && currUser.cart.length > 0) { %>
                                <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-dark border border-white" style="font-size: 0.5rem; padding: 0.25em 0.4em;">
                                    <%= currUser.cart.length %>
                                </span>
                            <% } %>
                        </a>
                        <div class="notifications me-3">
                            <i class="fa-regular fa-bell fa-lg"></i>
                            <span class="badge-dot"></span>
                        </div>
                    </div>
                    <div class="user-profile dropdown">
                        <div class="d-flex align-items-center cursor-pointer" id="profileDropdown" data-bs-toggle="dropdown">
                            <div class="user-info me-2 text-end d-none d-sm-block">
                                <p class="mb-0 fw-bold"><%= currUser ? currUser.username : '' %></p>
                                <span class="text-muted small"><%= currUser && currUser.role ? currUser.role.charAt(0).toUpperCase() + currUser.role.slice(1) : '' %></span>
                            </div>
                            <img src="https://ui-avatars.com/api/?name=<%= currUser ? currUser.username : 'User' %>&background=random" alt="avatar" class="avatar">
                        </div>
                        <ul class="dropdown-menu dropdown-menu-end shadow-lg border-0 mt-3">
                            <li class="px-3 py-2 text-muted small border-bottom">Welcome, <%= currUser ? currUser.username : 'Guest' %>!</li>
                            <li><a class="dropdown-item py-2" href="/profile"><i class="fa-regular fa-user me-2"></i> My Profile</a></li>
                            <li><a class="dropdown-item py-2" href="/settings"><i class="fa-solid fa-gear me-2"></i> Settings</a></li>
                            <li><hr class="dropdown-divider"></li>
                            <li><a class="dropdown-item py-2 text-danger" href="/logout"><i class="fa-solid fa-power-off me-2"></i> Sign out</a></li>
                        </ul>
                    </div>
                </div>
            </header>

            <!-- Dashboard Body -->
            <div class="dashboard-body p-4">
                <%- include("../includes/flash.ejs") %> 
                <%- body %>
            </div>
        </main>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // Sidebar Toggle for Mobile
        const sidebar = document.querySelector('.sidebar');
        const toggleBtn = document.getElementById('sidebarToggle');
        const closeBtn = document.getElementById('sidebarClose');

        if(toggleBtn) {
            toggleBtn.addEventListener('click', () => {
                sidebar.classList.add('mobile-open');
            });
        }
        if(closeBtn) {
            closeBtn.addEventListener('click', () => {
                sidebar.classList.remove('mobile-open');
            });
        }
    </script>
</body>
</html>
