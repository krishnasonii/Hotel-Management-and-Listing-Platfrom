<% layout("/layouts/dashboard") %>

<div class="row">
    <div class="col-md-8 mx-auto">
        <div class="data-card">
            <h4 class="fw-bold mb-4">Account Settings</h4>
            <form>
                <div class="mb-3">
                    <label class="form-label text-muted small fw-bold">Username</label>
                    <input type="text" class="form-control rounded-3" value="<%= currUser.username %>" readonly>
                </div>
                <div class="mb-3">
                    <label class="form-label text-muted small fw-bold">Email Address</label>
                    <input type="email" class="form-control rounded-3" value="<%= currUser.email %>" readonly>
                </div>
                <div class="mb-4">
                    <label class="form-label text-muted small fw-bold">Role</label>
                    <input type="text" class="form-control rounded-3" value="<%= currUser.role.toUpperCase() %>" readonly>
                </div>
                
                <hr class="my-4">
                
                <h5 class="fw-bold mb-3">Preferences</h5>
                <div class="form-check form-switch mb-3">
                    <input class="form-check-input" type="checkbox" id="emailNotif" checked>
                    <label class="form-check-label" for="emailNotif">Email Notifications for new bookings</label>
                </div>
                <div class="form-check form-switch mb-4">
                    <input class="form-check-input" type="checkbox" id="darkMode">
                    <label class="form-check-label" for="darkMode">Enable Dark Mode (Beta)</label>
                </div>
                
                <button type="button" class="btn btn-primary rounded-pill px-5">Save Changes</button>
            </form>
        </div>
    </div>
</div>
