<% layout("/layouts/boilerplate") %>
<div class="row mt-5 animate__animated animate__fadeIn">
    <div class="col-md-8 offset-md-2 text-center">
        <div class="mb-5 mt-4">
            <div class="success-icon-wrapper mb-4">
                <i class="fa-solid fa-circle-check fa-6x text-success"></i>
            </div>
            <h1 class="fw-bold display-4">Booking Confirmed!</h1>
            <p class="text-muted fs-5">Pack your bags! Your stay at <strong><%= booking.listing.title %></strong> is all set.</p>
        </div>

        <div class="card border-0 shadow-lg rounded-4 overflow-hidden mb-5 text-start">
            <div class="row g-0">
                <div class="col-md-4">
                    <img src="<%= booking.listing.image.url %>" class="img-fluid h-100" style="object-fit: cover; min-height: 250px;">
                </div>
                <div class="col-md-8 p-4">
                    <div class="d-flex justify-content-between align-items-start mb-3">
                        <div>
                            <h4 class="fw-bold mb-1"><%= booking.listing.title %></h4>
                            <p class="text-muted small mb-0"><i class="fa-solid fa-location-dot me-1"></i> <%= booking.listing.location %>, <%= booking.listing.country %></p>
                        </div>
                        <span class="badge bg-success-light text-success px-3 py-2 rounded-pill fw-bold">ID: #<%= booking._id.toString().slice(-6).toUpperCase() %></span>
                    </div>

                    <div class="row g-3 py-3 border-top border-bottom mb-3">
                        <div class="col-6">
                            <label class="small text-muted fw-bold d-block text-uppercase">Check-In</label>
                            <span class="fw-bold"><%= booking.checkIn.toDateString() %></span>
                        </div>
                        <div class="col-6 text-end">
                            <label class="small text-muted fw-bold d-block text-uppercase">Checkout</label>
                            <span class="fw-bold"><%= booking.checkOut.toDateString() %></span>
                        </div>
                        <div class="col-6">
                            <label class="small text-muted fw-bold d-block text-uppercase">Guests</label>
                            <span><%= booking.guests %> Guest<%= booking.guests > 1 ? 's' : '' %></span>
                        </div>
                        <div class="col-6 text-end">
                            <label class="small text-muted fw-bold d-block text-uppercase">Total Paid</label>
                            <span class="text-success fw-bold">₹<%= booking.totalPrice.toLocaleString("en-IN") %></span>
                        </div>
                    </div>

                    <div class="alert alert-light border-0 bg-light p-3 small rounded-3">
                        <i class="fa-solid fa-circle-info me-2 text-primary"></i> A confirmation email has been sent to <strong><%= booking.email %></strong>. The host will contact you at <strong><%= booking.phone %></strong> if needed.
                    </div>
                </div>
            </div>
        </div>

        <div class="d-flex justify-content-center gap-3 pb-5">
            <a href="/listings" class="btn btn-outline-dark rounded-pill px-5 py-3 fw-bold">Explore More</a>
            <a href="/user/dashboard" class="btn btn-danger rounded-pill px-5 py-3 fw-bold shadow">My Dashboard</a>
        </div>
    </div>
</div>

<style>
    .bg-success-light { background-color: #d1e7dd; }
    .success-icon-wrapper {
        animation: bounceIn 0.8s cubic-bezier(0.36, 0, 0.66, -0.56) both;
    }
    @keyframes bounceIn {
        0% { transform: scale(0.3); opacity: 0; }
        50% { transform: scale(1.05); opacity: 1; }
        70% { transform: scale(0.9); }
        100% { transform: scale(1); }
    }
</style>
