<% layout("/layouts/dashboard") %>
<div class="container-fluid">
    <div class="row mb-4">
        <div class="col-12">
            <h2 class="fw-bold">User Management</h2>
            <p class="text-muted">Manage system users, roles, and account statuses.</p>
        </div>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-md-4">
            <div class="card border-0 shadow-sm p-4 rounded-4 h-100">
                <h6 class="text-muted mb-2 small">Total Active Users</h6>
                <div class="d-flex align-items-end justify-content-between">
                    <h3 class="fw-bold mb-0">1,240</h3>
                    <span class="text-success small"><i class="fa-solid fa-arrow-up me-1"></i> 8% growth</span>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-sm p-4 rounded-4 h-100">
                <h6 class="text-muted mb-2 small">New Registrations</h6>
                <div class="d-flex align-items-end justify-content-between">
                    <h3 class="fw-bold mb-0">12</h3>
                    <span class="text-muted small">Last 24 hours</span>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-sm p-4 rounded-4 h-100 border-start border-danger border-5">
                <h6 class="text-muted mb-2 small">Flagged Accounts</h6>
                <div class="d-flex align-items-end justify-content-between">
                    <h3 class="fw-bold mb-0 text-danger">3</h3>
                    <span class="text-danger small">Action required</span>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-12">
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body p-4">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle">
                            <thead class="table-light">
                                <tr>
                                    <th>User Info</th>
                                    <th>Role</th>
                                    <th>Email</th>
                                    <th>Status</th>
                                    <th>Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% allUsers.forEach(user => { %>
                                    <tr>
                                        <td>
                                            <div class="d-flex align-items-center">
                                                <img src="https://ui-avatars.com/api/?name=<%= user.username %>&background=random" class="rounded-circle me-3" style="width: 40px; height: 40px;">
                                                <span class="fw-bold"><%= user.username %></span>
                                            </div>
                                        </td>
                                        <td><span class="badge bg-primary-light text-primary px-3 py-2 rounded-pill"><%= user.role.toUpperCase() %></span></td>
                                        <td><%= user.email %></td>
                                        <td>
                                            <% if (user.isBlocked) { %>
                                                <span class="badge bg-danger text-white px-3 py-2 rounded-pill small">Blocked</span>
                                            <% } else { %>
                                                <span class="badge bg-success text-white px-3 py-2 rounded-pill small">Active</span>
                                            <% } %>
                                        </td>
                                        <td>
                                            <div class="dropdown">
                                                <button class="btn btn-light btn-sm rounded-pill px-3 dropdown-toggle shadow-sm" type="button" data-bs-toggle="dropdown">Manage</button>
                                                <ul class="dropdown-menu border-0 shadow-lg">
                                                    <li><a class="dropdown-item py-2" href="#"><i class="fa-solid fa-user-pen me-2"></i> Edit User</a></li>
                                                    <li><a class="dropdown-item py-2" href="#"><i class="fa-solid fa-key me-2"></i> Reset Password</a></li>
                                                    <li><hr class="dropdown-divider"></li>
                                                    <li>
                                                        <form action="/admin/users/<%= user._id %>/toggle-block?_method=PATCH" method="POST">
                                                            <button class="dropdown-item py-2 <%= user.isBlocked ? 'text-success' : 'text-warning' %>" type="submit">
                                                                <i class="fa-solid <%= user.isBlocked ? 'fa-user-check' : 'fa-user-slash' %> me-2"></i> 
                                                                <%= user.isBlocked ? 'Unblock Account' : 'Suspend Account' %>
                                                            </button>
                                                        </form>
                                                    </li>
                                                    <li>
                                                        <form action="/admin/users/<%= user._id %>?_method=DELETE" method="POST" onsubmit="return confirm('Are you sure you want to delete this user permanently?')">
                                                            <button class="dropdown-item py-2 text-danger" type="submit">
                                                                <i class="fa-solid fa-trash-can me-2"></i> Delete User
                                                            </button>
                                                        </form>
                                                    </li>
                                                </ul>
                                            </div>
                                        </td>
                                    </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
