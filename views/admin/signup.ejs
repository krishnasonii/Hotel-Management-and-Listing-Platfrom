<% layout("/layouts/boilerplate") %>

<div class="row mt-5">
    <div class="col-md-6 offset-md-3 col-lg-5 offset-lg-3 px-3">
        <div class="auth-card" style="border-top: 4px solid #1e293b;">
            <div class="text-center mb-4">
                <i class="fa-solid fa-user-plus fa-3x mb-3" style="color: #1e293b;"></i>
                <h2 class="fw-bold">Admin Registration</h2>
                <p class="text-muted small">Create an administrator account to manage the platform</p>
            </div>
            
            <% if (locals.currUser) { %>
                <div class="text-center py-4">
                    <p class="text-muted">You are already signed in as <strong><%= currUser.username %></strong>.</p>
                    <a href="/logout" class="btn btn-danger-custom w-100 py-2 shadow-sm mb-3">
                        Sign out
                    </a>
                    <a href="/admin/dashboard" class="btn btn-outline-secondary w-100 py-2 rounded-3">
                        Go to Dashboard
                    </a>
                </div>
            <% } else { %>
                <form action="/auth/admin/signup" method="post" class="needs-validation" novalidate>
                    <div class="mb-3">
                        <label for="username" class="form-label small fw-bold text-muted">Username</label>
                        <input name="username" id="username" type="text" class="form-control rounded-3 py-2" placeholder="e.g. admin_doe" required>
                        <div class="valid-feedback">Looks good!</div>
                    </div>

                    <div class="mb-3">
                        <label for="email" class="form-label small fw-bold text-muted">Email Address</label>
                        <input name="email" id="email" type="email" class="form-control rounded-3 py-2" placeholder="admin@example.com" required>
                        <div class="valid-feedback">Valid email format</div>
                    </div>

                    <div class="mb-4">
                        <label for="password" class="form-label small fw-bold text-muted">Password</label>
                        <input name="password" id="password" type="password" class="form-control rounded-3 py-2" placeholder="••••••••" required>
                        <div class="invalid-feedback">Password must be at least 6 characters</div>
                    </div>

                    <button class="btn w-100 py-2 shadow-sm text-white" style="background-color: #1e293b;">
                        Sign Up as Admin
                    </button>
                    
                    <div class="mt-4 text-center">
                        <p class="small text-muted mb-0">Already have an admin account? <a href="/auth/admin/login" class="fw-bold text-decoration-none" style="color: #1e293b;">Login here</a></p>
                        <div class="divider border-top my-3 opacity-25"></div>
                        <a href="/auth/select-role" class="btn btn-outline-dark btn-sm rounded-pill px-4">
                            <i class="fa-solid fa-arrow-left me-1"></i> Back to Role Selection 
                        </a>
                    </div>
                </form>
            <% } %>
        </div>
    </div>
</div>
