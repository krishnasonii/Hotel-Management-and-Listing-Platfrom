<% layout("/layouts/boilerplate") %>

<div class="row mt-5">
    <div class="col-md-6 offset-md-3 col-lg-4 offset-lg-4 px-3">
        <div class="auth-card" style="border-top: 4px solid #1e293b;">
            <div class="text-center mb-4">
                <i class="fa-solid fa-user-shield fa-3x mb-3" style="color: #1e293b;"></i>
                <h2 class="fw-bold">Admin Portal</h2>
                <p class="text-muted small">Login to access your administrator dashboard</p>
            </div>
            
            <% if (locals.currUser) { %>
                <div class="text-center py-4">
                    <p class="text-muted">You are already signed in as <strong><%= currUser.username %></strong>.</p>
                    <a href="/logout" class="btn btn-danger-custom w-100 py-2 shadow-sm mb-3">
                        Sign out
                    </a>
                    <a href="/admin/dashboard" class="btn btn-outline-secondary w-100 py-2 rounded-3">
                        Go to Dashboard
                    </a>
                </div>
            <% } else { %>
                <form action="/auth/admin/login" method="post" class="needs-validation" novalidate>
                    <div class="mb-3">
                        <label for="username" class="form-label small fw-bold text-muted">Username</label>
                        <input name="username" id="username" type="text" class="form-control rounded-3 py-2" placeholder="Enter admin username" required>
                        <div class="invalid-feedback">Please enter your username</div>
                    </div>

                    <div class="mb-4">
                        <label for="password" class="form-label small fw-bold text-muted">Password</label>
                        <input name="password" id="password" type="password" class="form-control rounded-3 py-2" placeholder="••••••••" required>
                        <div class="invalid-feedback">Please enter your password</div>
                    </div>

                    <button class="btn w-100 py-2 shadow-sm text-white" style="background-color: #1e293b;">
                        Login as Admin
                    </button>
                    
                    <div class="mt-4 text-center">
                        <p class="small text-muted mb-3">Don't have an admin account? <a href="/auth/admin/signup" class="fw-bold text-decoration-none" style="color: #1e293b;">Sign up</a></p>
                        <div class="divider border-top my-3 opacity-25"></div>
                        <a href="/auth/select-role" class="btn btn-outline-dark btn-sm rounded-pill px-4">
                            <i class="fa-solid fa-arrow-left me-1"></i> Back to Role Selection 
                        </a>
                    </div>
                </form>
            <% } %>
        </div>
    </div>
</div>
