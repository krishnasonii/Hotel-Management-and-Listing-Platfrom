<% layout("/layouts/dashboard") %>
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<style>
    .glass-card { background: rgba(255, 255, 255, 0.95); backdrop-filter: blur(10px); border: 1px solid rgba(0,0,0,0.05); }
    .loyalty-badge { background: linear-gradient(135deg, #ff385c, #ff8a00); color: #fff; padding: 0.5rem 1rem; border-radius: 50px; font-weight: bold; font-size: 0.75rem; }
    .progress-bar-custom { height: 8px; border-radius: 10px; background: #eee; overflow: hidden; }
    .progress-bar-fill { height: 100%; background: #ff385c; transition: width 0.4s ease; }
    .icon-box-large { width: 60px; height: 60px; display: flex; align-items: center; justify-content: center; font-size: 1.5rem; }
</style>

<div class="container-fluid pb-5">
    
    <div class="row mb-5 pt-3">
        <div class="col-md-8">
            <h1 class="fw-bold display-6 mb-1">Explore, <%= currUser.username %>!</h1>
            <p class="text-muted fs-5">Ready for your next adventure?</p>
        </div>
        <div class="col-md-4 text-md-end d-flex align-items-center justify-content-md-end gap-3">
            <div class="text-end">
                <div class="small fw-bold text-muted mb-1 text-uppercase ls-wide">Loyalty Tier</div>
                <div class="loyalty-badge shadow-sm"><i class="fa-solid fa-crown me-1"></i> <%= stats.loyaltyTier %></div>
            </div>
        </div>
    </div>

    
    <div class="row g-4 mb-5">
        <div class="col-xl-3 col-md-6">
            <div class="card glass-card shadow-sm h-100 rounded-4 border-0 p-4">
                <div class="d-flex justify-content-between mb-3 align-items-start">
                    <div class="icon-box-large bg-danger-light text-danger rounded-4"><i class="fa-solid fa-suitcase"></i></div>
                    <span class="badge bg-light text-muted border fw-normal py-2 px-3 rounded-pill">+2 this mo</span>
                </div>
                <h6 class="text-muted fw-bold text-uppercase mb-1" style="font-size: 0.7rem;">Active Stays</h6>
                <h2 class="fw-bold mb-0"><%= stats.totalBookings %></h2>
            </div>
        </div>
        <div class="col-xl-3 col-md-6">
            <div class="card glass-card shadow-sm h-100 rounded-4 border-0 p-4">
                <div class="d-flex justify-content-between mb-3 align-items-center">
                    <div class="icon-box-large bg-primary-light text-primary rounded-4"><i class="fa-solid fa-user-check"></i></div>
                    <div class="text-end">
                        <span class="fw-bold d-block"><%= stats.profileProgress %>%</span>
                        <small class="text-muted">Complete</small>
                    </div>
                </div>
                <h6 class="text-muted fw-bold text-uppercase mb-2" style="font-size: 0.7rem;">Profile Strength</h6>
                <div class="progress-bar-custom mb-2">
                    <div class="progress-bar-fill" style="width: <%= stats.profileProgress %>%"></div>
                </div>
                <a href="/user/profile" class="text-primary small text-decoration-none fw-bold">Update profile <i class="fa-solid fa-chevron-right ms-1"></i></a>
            </div>
        </div>
        <div class="col-xl-3 col-md-6">
            <div class="card glass-card shadow-sm h-100 rounded-4 border-0 p-4">
                <div class="icon-box-large bg-warning-light text-warning rounded-4 mb-3"><i class="fa-solid fa-wallet"></i></div>
                <h6 class="text-muted fw-bold text-uppercase mb-1" style="font-size: 0.7rem;">Travel Wallet</h6>
                <h2 class="fw-bold mb-0">₹2,450</h2>
                <div class="text-muted small mt-1">Pending Cashback</div>
            </div>
        </div>
        <div class="col-xl-3 col-md-6">
            <div class="card glass-card shadow-sm h-100 rounded-4 border-0 p-4">
                <div class="icon-box-large bg-info-light text-info rounded-4 mb-3"><i class="fa-solid fa-bullhorn"></i></div>
                <h6 class="text-muted fw-bold text-uppercase mb-1" style="font-size: 0.7rem;">Latest Alert</h6>
                <div class="fw-bold small mb-2 text-truncate-2">Check-in open for The Grand Hotel</div>
                <a href="/user/bookings" class="btn btn-sm btn-outline-dark rounded-pill px-3 fw-bold" style="font-size: 0.7rem;">Action Required</a>
            </div>
        </div>
    </div>

    
    <div class="row g-4">
        
        <div class="col-lg-8">
            <div class="card glass-card border-0 shadow-sm rounded-4 mb-4">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <h5 class="fw-bold mb-0">Travel Trends</h5>
                        <div class="dropdown">
                            <button class="btn btn-light btn-sm rounded-pill fw-bold" type="button">Last 6 Months</button>
                        </div>
                    </div>
                    <canvas id="travelChart" height="120"></canvas>
                </div>
            </div>

            <div class="card glass-card border-0 shadow-sm rounded-4">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <h5 class="fw-bold mb-0">Your Upcoming Stays</h5>
                        <a href="/user/bookings" class="text-danger small text-decoration-none fw-bold">View History</a>
                    </div>
                    <% if (upcomingStays.length === 0) { %>
                        <div class="text-center py-5 bg-light rounded-4">
                            <i class="fa-solid fa-earth-americas fa-3x text-muted opacity-25 mb-3"></i>
                            <p class="text-muted mb-4">No trips lined up. The world is calling!</p>
                            <a href="/listings" class="btn btn-danger rounded-pill px-5 fw-bold shadow-sm">Start Searching</a>
                        </div>
                    <% } else { %>
                        <div class="table-responsive">
                            <table class="table table-hover align-middle">
                                <thead class="table-light rounded-3">
                                    <tr>
                                        <th class="border-0">Hotel & Location</th>
                                        <th class="border-0">Check-in</th>
                                        <th class="border-0">Status</th>
                                        <th class="border-0 text-end">Action</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% upcomingStays.forEach(stay => { %>
                                        <tr>
                                            <td class="border-0 py-3">
                                                <div class="d-flex align-items-center">
                                                    <img src="<%= stay.listing.image.url %>" class="rounded-3 me-3" style="width: 40px; height: 40px; object-fit: cover;">
                                                    <span class="fw-bold"><%= stay.listing.title %></span>
                                                </div>
                                            </td>
                                            <td class="border-0"><%= stay.checkIn.toDateString() %></td>
                                            <td class="border-0"><span class="badge bg-success-light text-success px-3 py-2 rounded-pill">Confirmed</span></td>
                                            <td class="border-0 text-end"><a href="/user/bookings" class="btn btn-outline-dark btn-sm rounded-pill px-3 fw-bold">Review Details</a></td>
                                        </tr>
                                    <% }) %>
                                </tbody>
                            </table>
                        </div>
                    <% } %>
                </div>
            </div>
        </div>

        
        <div class="col-lg-4">
            <div class="card glass-card border-0 shadow-sm rounded-4 mb-4">
                <div class="card-body p-4">
                    <h5 class="fw-bold mb-4">Quick Shortcuts</h5>
                    <div class="list-group list-group-flush">
                        <a href="/user/orders" class="list-group-item list-group-item-action border-0 px-0 py-3 d-flex align-items-center">
                            <i class="fa-solid fa-concierge-bell text-danger me-3 fs-5"></i>
                            <div class="flex-grow-1">
                                <span class="d-block fw-bold small">Service Orders</span>
                                <small class="text-muted">In-room dining & amenities</small>
                            </div>
                        </a>
                        <a href="/user/wishlist" class="list-group-item list-group-item-action border-0 px-0 py-3 d-flex align-items-center">
                            <i class="fa-solid fa-heart text-primary me-3 fs-5"></i>
                            <div class="flex-grow-1">
                                <span class="d-block fw-bold small">Saved listings</span>
                                <small class="text-muted">Properties you love</small>
                            </div>
                        </a>
                        <a href="/user/profile" class="list-group-item list-group-item-action border-0 px-0 py-3 d-flex align-items-center">
                            <i class="fa-solid fa-id-card text-success me-3 fs-5"></i>
                            <div class="flex-grow-1">
                                <span class="d-block fw-bold small">Profile Settings</span>
                                <small class="text-muted">Account & security</small>
                            </div>
                        </a>
                        <a href="/listings" class="list-group-item list-group-item-action border-0 px-0 py-3 d-flex align-items-center">
                            <i class="fa-solid fa-compass text-warning me-3 fs-5"></i>
                            <div class="flex-grow-1">
                                <span class="d-block fw-bold small">Browse Hotels</span>
                                <small class="text-muted">View all listings</small>
                            </div>
                        </a>
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        const ctx = document.getElementById('travelChart').getContext('2d');
        
        // Pass Monthly Data from EJS to JS
        const monthLabels = <%- JSON.stringify(monthlyData.map(d => d.month)) %>;
        const monthCounts = <%- JSON.stringify(monthlyData.map(d => d.count)) %>;

        new Chart(ctx, {
            type: 'line',
            data: {
                labels: monthLabels,
                datasets: [{
                    label: 'Bookings',
                    data: monthCounts,
                    borderColor: '#ff385c',
                    backgroundColor: 'rgba(255, 56, 92, 0.1)',
                    borderWidth: 3,
                    tension: 0.4,
                    fill: true,
                    pointBackgroundColor: '#ff385c',
                    pointBorderColor: '#fff',
                    pointBorderWidth: 2,
                    pointRadius: 4
                }]
            },
            options: {
                responsive: true,
                plugins: { legend: { display: false } },
                scales: {
                    y: { 
                        beginAtZero: true, 
                        grid: { display: false },
                        ticks: { stepSize: 1 }
                    },
                    x: { grid: { display: false } }
                }
            }
        });
    });
</script>
