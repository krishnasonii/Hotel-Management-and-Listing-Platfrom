<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Invoice #<%= booking._id.toString().slice(-6).toUpperCase() %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        body { background-color: #f8f9fa; font-family: 'Inter', sans-serif; }
        .invoice-card { background: white; border-radius: 1rem; box-shadow: 0 10px 30px rgba(0,0,0,0.05); padding: 3rem; margin-top: 3rem; margin-bottom: 3rem; border: none; }
        .invoice-header { border-bottom: 2px solid #eee; padding-bottom: 2rem; margin-bottom: 2rem; }
        .logo { font-size: 2rem; font-weight: 800; color: #ff385c; text-decoration: none; }
        .invoice-title { text-transform: uppercase; letter-spacing: 2px; color: #999; font-weight: 700; margin-bottom: 0; }
        .table thead th { border-top: none; text-transform: uppercase; font-size: 0.8rem; color: #999; }
        .total-row { background: #f8f9fa; border-radius: 0.5rem; padding: 1.5rem; margin-top: 2rem; }
        .status-stamp { position: absolute; top: 150px; right: 80px; transform: rotate(-15deg); font-weight: 900; font-size: 4rem; opacity: 0.1; pointer-events: none; }
        .btn-print { position: fixed; top: 2rem; right: 2rem; border-radius: 2rem; }
        @media print {
            .btn-print { display: none; }
            body { background-color: white; }
            .invoice-card { box-shadow: none; margin-top: 0; padding: 1rem; }
        }
    </style>
</head>
<body>

    <button onclick="window.print()" class="btn btn-dark btn-print px-4 py-2 shadow"><i class="fa-solid fa-print me-2"></i>Print Invoice</button>

    <div class="container">
        <div class="row">
            <div class="col-lg-8 offset-lg-2">
                <div class="invoice-card position-relative">
                    
                    <% if (booking.status === 'confirmed') { %>
                        <div class="status-stamp text-success">PAID</div>
                    <% } else if (booking.status === 'cancelled') { %>
                        <div class="status-stamp text-danger">CANCELLED</div>
                    <% } %>

                    <div class="invoice-header d-flex justify-content-between align-items-center">
                        <div>
                            <div class="logo"><i class="fa-solid fa-hotel me-2"></i>Hotelify</div>
                            <p class="text-muted small mt-2">123 Travel Road, Mumbai, IN</p>
                        </div>
                        <div class="text-end">
                            <h2 class="invoice-title">Invoice</h2>
                            <p class="fw-bold mb-0">#<%= booking._id.toString().slice(-6).toUpperCase() %></p>
                            <p class="text-muted small"><%= new Date(booking.createdAt).toLocaleDateString() %></p>
                        </div>
                    </div>

                    <div class="row mb-5">
                        <div class="col-6">
                            <h6 class="text-muted text-uppercase small fw-bold">Billed To:</h6>
                            <p class="fw-bold mb-0"><%= booking.user.username %></p>
                            <p class="text-muted"><%= booking.email %><br><%= booking.phone %></p>
                        </div>
                        <div class="col-6 text-end">
                            <h6 class="text-muted text-uppercase small fw-bold">Property:</h6>
                            <p class="fw-bold mb-0"><%= booking.listing.title %></p>
                            <p class="text-muted"><%= booking.listing.location %>, <%= booking.listing.country %></p>
                        </div>
                    </div>

                    <table class="table align-middle">
                        <thead>
                            <tr>
                                <th>Description</th>
                                <th class="text-center">Dates</th>
                                <th class="text-end">Amount</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td>
                                    <h6 class="mb-0 fw-bold">Accommodation</h6>
                                    <small class="text-muted"><%= booking.guests %> Guest<%= booking.guests > 1 ? 's' : '' %></small>
                                </td>
                                <td class="text-center">
                                    <%= booking.checkIn.toLocaleDateString() %> - <%= booking.checkOut.toLocaleDateString() %>
                                </td>
                                <td class="text-end fw-bold">₹<%= booking.totalPrice.toLocaleString("en-IN") %></td>
                            </tr>
                        </tbody>
                    </table>

                    <div class="total-row d-flex justify-content-between align-items-center">
                        <div class="ps-2">
                            <p class="text-muted small mb-0">Payment Method: Online Credit/Debit</p>
                            <p class="text-muted small mb-0">Status: <span class="fw-bold text-<%= booking.status==='confirmed'?'success':'danger' %>"><%= booking.status.toUpperCase() %></span></p>
                        </div>
                        <div class="text-end pe-2">
                            <h6 class="text-muted text-uppercase small fw-bold">Total Amount Paid</h6>
                            <h2 class="fw-bold text-danger mb-0">₹<%= booking.totalPrice.toLocaleString("en-IN") %></h2>
                        </div>
                    </div>

                    <div class="mt-5 pt-5 text-center text-muted small">
                        <p>Thank you for choosing Hotelify. We hope you have a wonderful stay!</p>
                        <p class="mb-0">This is a computer-generated invoice and doesn't require a signature.</p>
                    </div>

                </div>
            </div>
        </div>
    </div>

</body>
</html>
