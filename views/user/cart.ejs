<% layout("/layouts/dashboard") %>
<div class="container-fluid">
    <div class="row mb-4">
        <div class="col-md-8">
            <h2 class="fw-bold">My Cart</h2>
            <p class="text-muted">Save your favorite hotels here and book them later.</p>
        </div>
    </div>

    <div class="row g-4">
        <% if (cart.length === 0) { %>
            <div class="col-12 text-center py-5">
                <div class="bg-light d-inline-block rounded-circle p-4 mb-3">
                    <i class="fa-solid fa-cart-shopping fa-4x text-muted opacity-25"></i>
                </div>
                <h3 class="text-muted fw-bold">Your cart is empty</h3>
                <p class="text-muted">Start exploring and save your favorite stays!</p>
                <a href="/listings" class="btn btn-primary rounded-pill px-4 shadow-sm">Explore Hotels</a>
            </div>
        <% } %>

        <% cart.forEach(listing => { %>
            <div class="col-12">
                <div class="card border-0 shadow-sm rounded-4 overflow-hidden mb-3">
                    <div class="row g-0">
                        <div class="col-md-4 position-relative">
                            <img src="<%= listing.image.url %>" class="img-fluid h-100" style="object-fit: cover;" alt="<%= listing.title %>">
                            <div class="position-absolute top-0 end-0 p-2">
                                <form action="/listings/<%= listing._id %>/wishlist" method="POST">
                                    <button type="submit" class="wishlist-btn shadow-sm" style="width: 34px; height: 34px;">
                                        <% if (currUser.wishlist && currUser.wishlist.some(id => id.toString() === listing._id.toString())) { %>
                                            <i class="fa-solid fa-heart text-danger"></i>
                                        <% } else { %>
                                            <i class="fa-regular fa-heart"></i>
                                        <% } %>
                                    </button>
                                </form>
                            </div>
                        </div>
                        <div class="col-md-8">
                            <div class="card-body p-4 d-flex flex-column h-100">
                                <div class="d-flex justify-content-between align-items-<ctrl94> mb-2">
                                    <div>
                                        <h5 class="fw-bold mb-1"><%= listing.title %></h5>
                                        <p class="text-muted small mb-0"><i class="fa-solid fa-location-dot me-1"></i> <%= listing.location %>, <%= listing.country %></p>
                                    </div>
                                    <div class="text-end">
                                        <span class="badge bg-light text-dark fw-normal border px-3 py-2 rounded-4 mb-2"><%= listing.category %></span>
                                        <h4 class="fw-bold text-dark mb-0">₹<%= listing.price?.toLocaleString("en-IN") %> <span class="text-muted fs-6 fw-normal">/ night</span></h4>
                                    </div>
                                </div>
                                <p class="text-muted small my-3 text-truncate-2"><%= listing.description %></p>
                                <div class="d-flex gap-3 mt-auto pt-3 border-top">
                                    <a href="/listings/<%= listing._id %>" class="btn btn-dark rounded-pill px-4 shadow-sm">Book This Stay</a>
                                    <form action="/listings/<%= listing._id %>/cart" method="POST">
                                        <button type="submit" class="btn btn-outline-danger rounded-pill px-4 shadow-sm">Remove from Cart</button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        <% }) %>
    </div>
</div>

<style>
.text-truncate-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
}

.wishlist-btn {
    background: white;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    border: none;
    cursor: pointer;
    transition: 0.2s ease;
    box-shadow: 0 4px 8px rgba(0,0,0,0.1);
}

.wishlist-btn:hover {
    transform: scale(1.1);
}

.wishlist-btn i {
    font-size: 1rem;
}
</style>
